"item_H639BW"],"settings":{"full_width":true,"subheading":"","title":"Design to Inspire","content":"<p>Made in collaboration with McLaren Automotive, these balance bikes represent the utmost in quality and innovation. The bikes bring meticulous design and innovation into your child’s world.<\/p>","button_text":"","button_url":"","text_position":"start","background":"","background_gradient":"","text_color":"","heading_color":"","heading_gradient":"","button_background":"","button_text_color":"","accordion_background":"","accordion_text_color":""}},"video_jdAKz9":{"type":"video","blocks":{"play_wiMKpx":{"type":"play","settings":{}},"heading_TT7nKU":{"type":"heading","settings":{"text":"","heading_tag":"h1"}}},"block_order":["play_wiMKpx","heading_TT7nKU"],"settings":{"full_width":true,"allow_transparent_header":false,"autoplay":true,"video_size":"auto","video":"shopify:\/\/files\/videos\/Official_video_of_the_McLaren_2021_collection_1.mp4","external_video_url":"https:\/\/www.youtube.com\/watch?v=_9VUPq3SxOc","text_color":"#ffffff","overlay_color":"#000000","overlay_opacity":30}},"rich_text_xpUPF4":{"type":"rich-text","blocks":{"subheading_9LHF9G":{"type":"subheading","settings":{"text":"Engineered for Every Stage"}},"heading_AfYRb4":{"type":"heading","settings":{"text":"The luxury stroller that grows with your child","heading_tag":"h2","text_color":"","gradient":""}},"richtext_9j3RyK":{"type":"richtext","settings":{"content":"<p>An innovative design that can transform from stroller to tricycle —designed to grow with your child through six stages, from 12 months and beyond.<\/p>"}}},"block_order":["subheading_9LHF9G","heading_AfYRb4","richtext_9j3RyK"],"disabled":true,"settings":{"full_width":true,"content_width":"small","text_position":"center","background":"","background_gradient":"","text_color":""}},"rich_text_8hAWQk":{"type":"rich-text","blocks":{"subheading_6qwNDh":{"type":"subheading","settings":{"text":"Unmatched Safety Features"}},"heading_nXqixp":{"type":"hea