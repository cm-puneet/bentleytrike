oducts_YXTBbY","text_xxXBJY"],"settings":{"full_width":true,"show_fixed_add_to_cart":true,"desktop_media_width":55,"desktop_media_layout":"carousel_thumbnails_bottom","mobile_media_size":"contained","mobile_carousel_control":"thumbnails","enable_video_autoplay":true,"enable_video_looping":true,"enable_image_zoom":true,"max_image_zoom_level":3,"background":"","background_gradient":"","text_color":"","input_background":"rgba(0,0,0,0)","input_text_color":""}},"accordion_content_EGhnWC":{"type":"accordion-content","blocks":{"item_xPccUw":{"type":"item","settings":{"icon":"none","icon_width":20,"title":"DESIGN","content":"<p>Designed in collaboration with Bentley Motors and your toddler’s needs in mind, the Bentley 6-in-1 Stroller \/ Tricycle is the perfect combination of elegance and function.<\/p>","page":""}},"item_tVpzTf":{"type":"item","disabled":true,"settings":{"icon":"none","icon_width":20,"title":"SPECIFICATION","content":"<p>REAR BRAKE: Yes<br\/><br\/>SEAT BELT: 5-point equipped with magnetic buckle<br\/><br\/>BASKET WITH COVER: Yes<br\/><br\/>FOOTRESTS: Basic (foldable) + accessory portable<br\/>(for infants)<br\/><br\/>PARENT RIDE CONTROL HANDLEBAR: Height adjustable, two-position<br\/><br\/>WHEEL DIAMETER:<br\/>12 inches (front wheel)<br\/>10 inches (rear wheels)<br\/><br\/>ADJUSTABLE BACK SUPPORT:<br\/>Two-position<br\/><br\/>FREE HANDLE BAR FUNCTION:Yes<br\/><br\/>STORAGE BAG: Compact, removable<br\/><br\/>SEAT COVER: Removable and machine washable<br\/><br\/>HEADRES: Yielding soft headrest with stitched Bentley<br\/>badge<br\/><br\/>WHEEL FENDERS: Yes<br\/><br\/>USED MATERIALS:<br\/>Iron, PVC, PP, ABC, TPR<br\/><br\/>FOLDABLE CANOPY: Two-position<br\/>FREEWHEEL FUNCTION: Yes<br\/><br\/>SEAT ROTATING FUNCTION: 180 grees<\/p>","page":"bentley-trike-assembly"}},"item_QMVwhR":{"type":"item","settings":{"icon":"none","icon_width":20,"title":"HOW TO ASSEMBLE","content":"<p>Every tool you need to put together your new Bentley Trike comes neatly organized in your box. Simply follow  <a href=\"https:\/\/bentleytrike.com\/pages\/bentley-trike-assembly\" target=\"_blank\" title=\"https:\/\/bentleytrike.com\/pages\/bentley-trike-assembly\">these simple steps<\/a>.<br\/><br\/>To help you even further, we’ve added more resources:<br\/><br\/><a href=\"https:\/\/bentleytrike.com\/pages\/bentley-trike-instructional-videos\" target=\"_blank\" title=\"https:\/\/bentleytrike.com\/pages\/bentley-trike-instructional-videos\">Bentley Trike Instructional Videos <br\/><br\/><\/a><a href=\"https:\/\/cdn.shopify.com\/s\/files\/1\/0008\/3368\/3521\/files\/Bentley_trike_Manual_Print_compressed.pdf?v=1764271651\" target=\"_blank\" title=\"https:\/\/cdn.shopify.com\/s\/files\/1\/0008\/3368\/3521\/files\/Bentley_trike_Manual_Print_compressed.pdf?v=1764271651\">Downloadable Assembly Manual (PDF)<\/a><\/p>","page":"bentley-trike-assembly"}},"item_LLNwn9":{"type":"item","settings":{"icon":"none","icon_width":20,"title":"SPARE PARTS","content":"<p>Every journey deserves to be seamless. If any part of your Bentley Trike needs replacing, continue the experience by ordering an official Bentley spare part <a href=\"\/products\/bentley-trike-spare-parts\" target=\"_blank\" title=\"Bentley Trike Spare Parts\">here<\/a>. <\/p>","page":""}},"item_H639BW":{"type":"item","settings":{"icon":"none","icon_width":20,"title":"WARRANTY","content":"<p>If you experience any issues with your Bentley Trike within the <strong>2-year warranty <\/strong>period, we’re here to ensure a seamless solution. Simply enter your details in the form below, and our team will assist you promptly.<\/p><p><em>Please note : Warranty coverage applies exclusively to purchases made directly from us. If purchased elsewhere, kindly reach out to the original retailer for assistance<\/em><\/p>","page":""}}},"block_order":["item_xPccUw","item_tVpzTf","item_QMVwhR","item_LLNwn9","item_H639BW"],"settings":{"full_width":true,"subheading":"","title":"Luxury in Every Detail","content":"<p>Inspired by the Bentley Continental GT, a luxury limited edition car  designed by the famous Bentley Motors LTD. The Bentley Convertible Stroller\/Trike for kids is an exceptional, luxurious tricycle combining style, comfort, and functionality. Designed with utmost attention to detail, this tricycle is perfect for children who appreciate the finer things in life.<\/p>","button_text":"","button_url":"","text_position":"start","background":"","background_gradient":"","text_color":"","heading_color":"","heading_gradient":"","button_background":"","button_text_color":"","accordion_background":"","accordion_text_color":""}},"rich_text_xpUPF4":{"type":"rich-text","blocks":{"subheading_9LHF9G":{"type":"subheading","settings":{"text":"Engineered for Every Stage"}},"heading_AfYRb4":{"type":"heading","settings":{"text":"The luxury stroller that grows with your child","heading_tag":"h2","text_color":"","gradient":""}},"richtext_9j3RyK":{"type":"richtext","settings":{"content":"<p>An innovative design that can transform from stroller to tricycle —designed to grow with your child through six stages, from 12 months and beyond.<\/p>"}}},"block_order":["subheading_9LHF9G","heading_AfYRb4","richtext_9j3RyK"],"disabled":true,"settings":{"full_width":true,"content_width":"small","text_position":"center","background":"","background_gradient":"","text_color":""}},"video_jdAKz9":{"type":"video","blocks":{"play_wiMKpx":{"type":"play","settings":{}},"heading_TT7nKU":{"type":"heading","settings":{"text":"","heading_tag":"h1"}}},"block_order":["play_wiMKpx","heading_TT7nKU"],"settings":{"full_width":true,"allow_transparent_header":false,"autoplay":true,"video_size":"auto","video":"shopify:\/\/files\/videos\/White saten.mp4","external_video_url":"https:\/\/www.youtube.com\/watch?v=_9VUPq3SxOc","text_color":"#ffffff","overlay_color":"#000000","overlay_opacity":30}},"rich_text_8hAWQk":{"type":"rich-text","blocks":{"subheading_6qwNDh":{"type":"subheading","settings":{"text":"Signature Features"}},"heading_n