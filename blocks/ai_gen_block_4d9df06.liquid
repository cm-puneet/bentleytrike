{% doc %}
  @prompt
    Use the Multiple images with text section of the theme. Get the codes and make it sure you are getting the the responsive on mobile codes too, and add the new features:
    1.) add star ratings above the heading
    2.) auto slide, increase the number of  images and retain the arrow buttons remove the Pagination Dots
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-multi-image-text-{{ ai_gen_id }} {
    position: relative;
    width: {{ block.settings.desktop_width_percent }}%;
    max-width: 100%;
    margin: 0 auto;
    overflow: hidden;
  }

  .ai-multi-image-text-slider-{{ ai_gen_id }} {
    display: flex;
    transition: transform 0.5s ease-in-out;
  }

  .ai-multi-image-text-slide-{{ ai_gen_id }} {
    min-width: 100%;
    display: flex;
    flex-direction: column;
    gap: 24px;
  }

  .ai-multi-image-text-content-{{ ai_gen_id }} {
    display: flex;
    flex-direction: column;
    align-items: {{ block.settings.text_alignment }};
    text-align: {{ block.settings.text_alignment }};
    gap: 16px;
  }

  .ai-multi-image-text-rating-{{ ai_gen_id }} {
    display: flex;
    gap: 4px;
    align-items: center;
  }

  .ai-multi-image-text-star-{{ ai_gen_id }} {
    width: {{ block.settings.star_size }}px;
    height: {{ block.settings.star_size }}px;
    fill: {{ block.settings.star_color }};
  }

  .ai-multi-image-text-star-{{ ai_gen_id }}.empty {
    fill: {{ block.settings.star_empty_color }};
  }

  .ai-multi-image-text-heading-{{ ai_gen_id }} {
    font-family: {{ block.settings.heading_font.family }}, {{ block.settings.heading_font.fallback_families }};
    font-weight: {{ block.settings.heading_font.weight }};
    font-size: {{ block.settings.heading_size }}px;
    color: {{ block.settings.heading_color }};
    margin: 0;
  }

  .ai-multi-image-text-text-{{ ai_gen_id }} {
    font-size: {{ block.settings.text_size }}px;
    color: {{ block.settings.text_color }};
    line-height: 1.6;
  }

  .ai-multi-image-text-image-wrapper-{{ ai_gen_id }} {
    width: 100%;
    border-radius: {{ block.settings.image_border_radius }}px;
    overflow: hidden;
  }

  .ai-multi-image-text-image-{{ ai_gen_id }} {
    width: 100%;
    height: auto;
    display: block;
  }

  .ai-multi-image-text-image-placeholder-{{ ai_gen_id }} {
    width: 100%;
    aspect-ratio: 16 / 9;
    background-color: #f4f4f4;
    display: flex;
    align-items: center;
    justify-content: center;
    position: relative;
  }

  .ai-multi-image-text-image-placeholder-{{ ai_gen_id }} svg {
    width: 100%;
    height: 100%;
    max-width: 300px;
    max-height: 300px;
  }

  .ai-multi-image-text-empty-state-{{ ai_gen_id }} {
    position: absolute;
    bottom: 20px;
    left: 50%;
    transform: translateX(-50%);
    padding: 12px 20px;
    font-size: 14px;
    color: #666;
    text-align: center;
  }

  .ai-multi-image-text-controls-{{ ai_gen_id }} {
    display: flex;
    justify-content: center;
    align-items: center;
    gap: 16px;
    margin-top: 24px;
  }

  .ai-multi-image-text-nav-{{ ai_gen_id }} {
    background-color: {{ block.settings.nav_button_color }};
    color: {{ block.settings.nav_button_text_color }};
    border: none;
    width: 40px;
    height: 40px;
    border-radius: 50%;
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
    transition: opacity 0.3s ease;
  }

  .ai-multi-image-text-nav-{{ ai_gen_id }}:hover {
    opacity: 0.8;
  }

  .ai-multi-image-text-nav-{{ ai_gen_id }}:disabled {
    opacity: 0.3;
    cursor: not-allowed;
  }

  @media screen and (min-width: 750px) {
    .ai-multi-image-text-slide-{{ ai_gen_id }} {
      flex-direction: {{ block.settings.layout }};
      align-items: center;
      gap: 48px;
    }

    .ai-multi-image-text-content-{{ ai_gen_id }} {
      flex: 1;
    }

    .ai-multi-image-text-image-wrapper-{{ ai_gen_id }} {
      flex: 1;
    }
  }

  @media screen and (max-width: 749px) {
    .ai-multi-image-text-heading-{{ ai_gen_id }} {
      font-size: {{ block.settings.heading_size | times: 0.8 }}px;
    }

    .ai-multi-image-text-text-{{ ai_gen_id }} {
      font-size: {{ block.settings.text_size | times: 0.9 }}px;
    }

    .ai-multi-image-text-star-{{ ai_gen_id }} {
      width: {{ block.settings.star_size | times: 0.8 }}px;
      height: {{ block.settings.star_size | times: 0.8 }}px;
    }
  }
{% endstyle %}

<multi-image-text-slider-{{ ai_gen_id }}
  class="ai-multi-image-text-{{ ai_gen_id }}"
  data-autoplay="{{ block.settings.autoplay }}"
  data-autoplay-speed="{{ block.settings.autoplay_speed }}"
  {{ block.shopify_attributes }}
>
  <div class="ai-multi-image-text-slider-{{ ai_gen_id }}">
    {% for i in (1..6) %}
      {% liquid
        assign image_key = 'image_' | append: i
        assign heading_key = 'heading_' | append: i
        assign text_key = 'text_' | append: i
        assign rating_key = 'rating_' | append: i

        assign image = block.settings[image_key]
        assign heading = block.settings[heading_key]
        assign text = block.settings[text_key]
        assign rating = block.settings[rating_key]
      %}

      <div class="ai-multi-image-text-slide-{{ ai_gen_id }}" data-slide="{{ i }}">
        <div class="ai-multi-image-text-content-{{ ai_gen_id }}">
          {% if block.settings.show_rating %}
            <div class="ai-multi-image-text-rating-{{ ai_gen_id }}">
              {% for star in (1..5) %}
                <svg
                  class="ai-multi-image-text-star-{{ ai_gen_id }} {% if star > rating %}empty{% endif %}"
                  xmlns="http://www.w3.org/2000/svg"
                  viewBox="0 0 24 24"
                >
                  <path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z" />
                </svg>
              {% endfor %}
            </div>
          {% endif %}

          {% if heading != blank %}
            <h2 class="ai-multi-image-text-heading-{{ ai_gen_id }}">{{ heading }}</h2>
          {% endif %}

          {% if text != blank %}
            <div class="ai-multi-image-text-text-{{ ai_gen_id }}">{{ text }}</div>
          {% endif %}
        </div>

        <div class="ai-multi-image-text-image-wrapper-{{ ai_gen_id }}">
          {% if image %}
            <img
              src="{{ image | image_url: width: 1200 }}"
              alt="{{ image.alt | escape }}"
              loading="lazy"
              width="{{ image.width }}"
              height="{{ image.height }}"
              class="ai-multi-image-text-image-{{ ai_gen_id }}"
            >
          {% else %}
            <div class="ai-multi-image-text-image-placeholder-{{ ai_gen_id }}">
              {{ 'image' | placeholder_svg_tag }}
              <div class="ai-multi-image-text-empty-state-{{ ai_gen_id }}">
                Add image {{ i }}
              </div>
            </div>
          {% endif %}
        </div>
      </div>
    {% endfor %}
  </div>

  <div class="ai-multi-image-text-controls-{{ ai_gen_id }}">
    <button
      class="ai-multi-image-text-nav-{{ ai_gen_id }} ai-multi-image-text-prev-{{ ai_gen_id }}"
      aria-label="Previous slide"
    >
      <svg
        width="20"
        height="20"
        viewBox="0 0 24 24"
        fill="none"
        stroke="currentColor"
        stroke-width="2"
      >
        <polyline points="15 18 9 12 15 6"></polyline>
      </svg>
    </button>

    <button
      class="ai-multi-image-text-nav-{{ ai_gen_id }} ai-multi-image-text-next-{{ ai_gen_id }}"
      aria-label="Next slide"
    >
      <svg
        width="20"
        height="20"
        viewBox="0 0 24 24"
        fill="none"
        stroke="currentColor"
        stroke-width="2"
      >
        <polyline points="9 18 15 12 9 6"></polyline>
      </svg>
    </button>
  </div>
</multi-image-text-slider-{{ ai_gen_id }}>

<script>
  (function() {
    class MultiImageTextSlider{{ ai_gen_id }} extends HTMLElement {
      constructor() {
        super();
        this.currentSlide = 0;
        this.totalSlides = 6;
        this.autoplayInterval = null;
      }

      connectedCallback() {
        this.slider = this.querySelector('.ai-multi-image-text-slider-{{ ai_gen_id }}');
        this.prevButton = this.querySelector('.ai-multi-image-text-prev-{{ ai_gen_id }}');
        this.nextButton = this.querySelector('.ai-multi-image-text-next-{{ ai_gen_id }}');

        this.setupEventListeners();

        const autoplay = this.dataset.autoplay === 'true';
        if (autoplay) {
          this.startAutoplay();
        }
      }

      disconnectedCallback() {
        this.stopAutoplay();
      }

      setupEventListeners() {
        this.prevButton.addEventListener('click', () => {
          this.stopAutoplay();
          this.goToPrevSlide();
          if (this.dataset.autoplay === 'true') {
            this.startAutoplay();
          }
        });

        this.nextButton.addEventListener('click', () => {
          this.stopAutoplay();
          this.goToNextSlide();
          if (this.dataset.autoplay === 'true') {
            this.startAutoplay();
          }
        });
      }

      goToSlide(index) {
        this.currentSlide = index;
        this.slider.style.transform = `translateX(-${this.currentSlide * 100}%)`;
      }

      goToPrevSlide() {
        this.currentSlide = this.currentSlide === 0 ? this.totalSlides - 1 : this.currentSlide - 1;
        this.goToSlide(this.currentSlide);
      }

      goToNextSlide() {
        this.currentSlide = this.currentSlide === this.totalSlides - 1 ? 0 : this.currentSlide + 1;
        this.goToSlide(this.currentSlide);
      }

      startAutoplay() {
        const speed = parseInt(this.dataset.autoplaySpeed) || 5000;
        this.autoplayInterval = setInterval(() => {
          this.goToNextSlide();
        }, speed);
      }

      stopAutoplay() {
        if (this.autoplayInterval) {
          clearInterval(this.autoplayInterval);
          this.autoplayInterval = null;
        }
      }
    }

    customElements.define('multi-image-text-slider-{{ ai_gen_id }}', MultiImageTextSlider{{ ai_gen_id }});
  })();
</script>

