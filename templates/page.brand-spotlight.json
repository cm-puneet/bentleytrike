    "multi_column_zBrXAm": {
      "type": "multi-column",
      "blocks": {
        "item_7JKAPm": {
          "type": "item",
          "settings": {
            "image": "shopify://shop_images/Wonder_Wise_-_Awesome_Activity_Table.jpg",
            "column_size": "3",
            "title": "Awesome Activity Table",
            "heading_tag": "h4",
            "content": "<p>A versatile play center that sparks curiosity and hands-on learning. From stackable animals and a shape sorter to a clever lift-out maze with a cotton storage bag, every detail is crafted in premium wood with non-toxic finishes for safe, thoughtful play.</p>",
            "link_url": "",
            "link_text": "",
            "link_style": "link"
          }
        },
        "item_K8kDY7": {
          "type": "item",
          "settings": {
            "image": "shopify://shop_images/Wonder_Wise_-_Busy_Box.jpg",
            "column_size": "3",
            "title": "Busy Box",
            "heading_tag": "h4",
            "content": "<p>An engaging cube designed to develop fine motor skills and sensory exploration. With interactive panels, a bead maze, and a compact, portable design, it delivers endless opportunities for learning and imaginative play.</p>",
            "link_url": "",
            "link_text": "",
            "link_style": "link"
          }
        },
        "item_yrTdct": {
          "type": "item",
          "settings": {
            "image": "shopify://shop_images/Wonder_Wise-_Dollhouse_Dollhouse_Accessories.jpg",
            "column_size": "3",
            "title": "Dollhouse & Accessories",
            "heading_tag": "h4",
            "content": "<p>A beautifully crafted reversible dollhouse that invites storytelling and creativity. Featuring multiple floors, staircases, and a removable roof, it scales perfectly with Wonder and Wise furniture for endless customization and imaginative adventures.</p>",
            "link_url": "",
            "link_text": "",
            "link_style": "link"
          }
        }
      },
