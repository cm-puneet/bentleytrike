n_mt":40,"button_mt_mobile":24,"button_style":"outline","arrow_size":50,"arrow_size_mobile":50,"arrow_icon_size":10,"arrow_icon_size_mobile":10,"arrow_border_thickness":1,"arrow_radius":6,"arrow_hover_effect":"color","arrow_show_desktop":true,"arrow_show_mobile":false,"image_border_color":"#000000","badge_color":"#000000","badge_bg_color":"#fef6ee","badge_border_color":"#000000","time_color":"#fef6ee","title_color":"#000000","text_color":"#000000","button_color":"#000000","button_hover_color":"#ffffff","button_bg_color":"","button_bg_hover_color":"#000000","button_border_color":"#000000","button_border_hover_color":"#000000","arrow_color":"#000000","arrow_hover_color":"#ffffff","arrow_bg_color":"#ffffff","arrow_bg_hover_color":"#000000","arrow_border_color":"#000000","arrow_border_hover_color":"#000000","background_color":"#fef6ee","background_gradient":"","border_color":"#000000","margin_top":0,"margin_bottom":0,"margin_horizontal":0,"margin_horizontal_mobile":0,"padding_top":36,"padding_bottom":36,"padding_horizontal":5,"padding_horizontal_mobile":1.5,"full_width":true,"content_width":1200,"border_thickness":0,"section_radius":0,"lazy":true}},"featured_collection_wjfakc":{"type":"featured-collection","disabled":true,"settings":{"collection":"baghera-ride-on-cars","products":[],"full_width":true,"stack_products":false,"show_progress_bar":false,"products_count":6,"products_per_row_mobile":"2","products_per_row_desktop":5,"subheading":"","title":"","content":"","link_url":"","link_text":"","background":"","background_gradient":"","text_color":"","heading_color":"","heading_gradient":"","product_card_background":"","product_card_text_color":""}},"rich_text_UnNFCc":{"type":"rich-text","blocks":{"subheading_Tz3MdE":{"type":"subheading","disabled":true,"settings":{"text":"Iconic Design, Realistic Features, Unmatched Fun"}},"heading_RUCgPb":{"type":"heading","settings":{"text":"Style & Functionality","heading_tag":"h2","text_color":"","gradient":""}},"richtext_4Ne86n":{"type":"richtext","settings":{"content":"<p>The Rito offers one of the easiest and most effective folding functions among convertible strollers\/trikes. This trike effortlessly folds down by simply clicking on a couple of buttons and folding it down on itself. The transforming trike then becomes small enough to pack in your car trunk or closet at home.<\/p>"}}},"block_order":["subheading_Tz3MdE","heading_RUCgPb","richtext_4Ne86n"],"settings":{"full_width":false,"content_width":"medium","text_position":"center","background":"rgba(0,0,0,0)","background_gradient":"","text_color":"#000000"}},"featured_collection_KzEh8L":{"type":"featured-collection","settings":{"collection":"rito-trike-2023","products":[],"full_width":true,"stack_products":true,"show_progress_bar":false,"products_count":8,"products_per_row_mobile":"2","products_per_row_desktop":4,"subheading":"","title":"","content":"","link_url":"","link_text":"","background":"","background_gradient":"","text_color":"","heading_color":"","heading_gradient":"","product_card_background":"","product_card_text_color":""}},"multiple_images_with_text_Xdf7et":{"type":"multiple-images-with-text","blocks":{"item_zfzdNq":{"type":"item","settings":{"image":"shopify:\/\/shop_images\/Alpine_Stage_1.jpg","image_rotation_degrees":-2,"subheading":"FOR 2 MONTHS & UP","title":"Stage 1","content":"<p>The seat is reclined back, the infant footrests can be deployed, and the free wheel\/free handle clutches can be engaged to ensure that the parent has full control of the trike.<\/p>","button_url":"","button_text":""}},"item_UTB6aT":{"type":"item","settings":{"image":"shopify:\/\/shop_images\/Alpine_Stage_2.jpg","image_rotation_degrees":1.5,"subheading":"FOR 36 MONTHS & UP","title":"Stage 2","content":"<p>The seat is inclined forward and the infant footrests can be folded up to allow your child to place their feet on the footrests. The free wheel\/free handle clutches should still be engaged.<\/p>","button_url":"","button_text":""}},"item_tEYWth":{"type":"item","settings":{"image":"shopify:\/\/shop_images\/Alpine_Stage_3.jpg","image_rotation_degrees":1.5,"subheading":"FOR 48 MONTHS & UP","title":"Stage 3","content":"<p>The parent-push handle and the backseat can be removed, and the free wheel\/free handle clutches disengaged to allow your child to take full control of the trike and enjoy a fun ride in the park.<\/p>","button_url":"","button_text":""}}},"block_order":["item_zfzdNq","item_UTB6aT","item_tEYWth"],"settings":{"full_width":true,"images_layout":"stacked","collage_images_alignment":"middle","background":"#d9d0c5","background_gradient":"","text_color":"","button_background":"","button_text_color":""}},"press_iJUY6T":{"type":"press","blocks":{"quote_XfCXD9":{"type":"quote","settings":{"logo_width":100,"author":"","content":"The Gray Rito Plus Ultimate Folding Trike is just what we were looking for. It was easy to assemble and the shipping was fast. Our grand daughter LOVES it! The pictures says it all! She is happy as are we with this trike.","show_rating":true,"rating":5}},"quote_xVQURz":{"type":"quote","settings":{"logo_width":100,"author":"","content":"My husband and I were looking for something very durable and decided to give this trike a try. To my delight, it was perfect. Easy set up, sturdy and the steering is so easy. We can push the baby with one hand and the steering is very smooth. We also love the fact she will get a few years of use out of it. Definitely would recommend.","show_rating":true,"rating":5}},"quote_QBHiRP":{"type":"quote","settings":{"logo_width":100,"author":"","content":"This is a great trike! Once you get the hang of unfolding\/folding it goes smoothly and is easy to transport. My only complaint is the canopy does not \"click\" or secure in, rather just slides on\/off and sometimes slides off when transporting. My son loves it and enjoys the smooth ride.","show_rating":true,"rating":5}}},"block_order":["quote_XfCXD9","quote_xVQURz","quote_QBHiRP"],"settings":{"full_width":true,"content_size":"medium","background":"","background_gradient":"","text_color":"","heading_color":"","heading_gradient":"","logo_item_background":"","logo_item_border":""}},"testimonials_Tt9Ryi":{"type":"testimonials","blocks":{"testimonial_D9W4iN":{"type":"testimonial","settings":{"round_avatar":true,"show_rating":true,"rating":5,"author":"Irina, D.","title":"Luxury on Wheels for My Little One!","content":"<p>I bought this beautiful green Bentley for my son Amir’s 2nd birthday, and it has been an absolute joy! The design is stunning, just like the real thing, with a sleek finish and amazing attention to detail. The ride is smooth, and the controls are easy to use, making it perfect for little drivers. Amir absolutely loves it, and seeing his excitement every time he gets in is priceless! A fantastic gift that combines style, fun, and comfort—highly recommend it!<\/p>"}},"testimonial_NW78di":{"type":"testimonial","settings":{"round_avatar":true,"show_rating":true,"rating":5,"author":"James G.","title":"Bentley GT","content":"<p>The kids car is nicely built. The features like the front and rear lights are cool. The lite gauge area is nice. Easy to assemble. Overall a great kids car for the price.<\/p>"}},"testimonial_xXhNmg":{"type":"testimonial","settings":{"round_avatar":true,"show_rating":true,"rating":4,"author":"Joshua A.","title":"Testimonial 3","content":"<p>Share what your customers are saying about your products, customer service or shipping rates.<\/p>"}}},"block_order":["testimonial_D9W4iN","testimonial_NW78di","testimonial_xXhNmg"],"disabled":true,"settings":{"full_width":true,"stack_testimonials":true,"subheading":"","title":"Testimonials","content":"","link_url":"","link_text":"","background":"","background_gradient":"","text_color":"","heading_color":"","heading_gradient":"","testimonial_card_background":"","testimonial_card_text_color":""}},"main":{"type":"main-collection","disabled":true,"settings":{"products_per_page":24,"products_per_row_mobile":"2","products_per_row_desktop":4,"filter_layout":"sidebar","show_sort_by":true,"show_filters":false,"show_filter_group_name":false,"show_filter_values_count":true,"open_first_filter_group":false}},"rich_text_fg4AAa":{"type":"rich-text","blocks":{"subheading_E6HLwn":{"type":"subheading","settings":{"text":"Timeless Durability"}},"heading_TJWMYy":{"type":"heading","settings":{"text":"Built to Last","heading_tag":"h2","text_color":"","gradient":""}},"richtext_NFnkTD":{"type":"richtext","settings":{"content":"<p>Built to last for years of adventure, Baghera Ride-On Cars handle indoor and outdoor play with ease, gliding smoothly over any flat terrain for endless fun across generations.<\/p>"}}},"block_order":["subheading_E6HLwn","heading_TJWMYy","richtext_NFnkTD"],"disabled":true,"settings":{"full_width":false,"content_width":"medium","text_position":"center","background":"#f2e9e4","background_gradient":"","text_color":"#000000"}},"media_with_text_Mgi7df":{"type":"media-with-text","blocks":{"image_9jUyr9":{"type":"image","settings":{"image":"shopify:\/\/shop_images\/Baghera_6.jpg","media_width":50,"media_position":"start","text_position":"place-self-center text-center","icon":"none","icon_width":48,"subheading":"","title":"A Classic That Never Fades","content":"<p>From Ride-Ons to Pedal Cars, Baghera’s timeless designs never go out of style. Their vintage charm suits any occasion, making them the perfect gift for little drivers ready to take the wheel.<\/p>","link_text":"","link_url":"","background":"#480d2a","background_gradient":"","text_color":"#ffffff","text_gradient":"","button_background":"","button_text_color":""}},"image_NHnBg4":{"type":"image","settings":{"image":"shopify:\/\/shop_images\/Baghera_5.jpg","media_width":50,"media_position":"start","text_position":"place-self-center text-center","icon":"none","icon_width":48,"subheading":"","title":"Meaningful Memories","content":"<p>By allowing your child to take the wheel, they develop confidence and essential motor skills, helping build independence and decision-making abilities, all while enjoying a fun and safe driving experience.<\/p>","link_text":"","link_url":"","background":"#394d46","background_gradient":"","text_color":"#ffffff","text_gradient":"","button_background":"","button_text_color":""}}},"block_order":["image_9jUyr9","image_NHnBg4"],"disabled":true,"settings":{"full_width":false,"alternate_media_position":true,"spacing":"small"}},"media_grid_XFmpJT":{"type":"media-grid","blocks":{"image_DPE7EB":{"type":"image","settings":{"image":"shopify:\/\/shop_images\/Baghera_1.jpg","title":"","heading_tag":"h4","link_url":"","link_text":"","mobile_text_position":"place-self-center text-center","desktop_column_span":2,"desktop_row_span":1,"desktop_text_position":"sm:place-self-center sm:text-center","background":"#000000","background_gradient":"","text_color":"#ffffff","text_gradient":"","button_background":"#000000","button_text_color":"#ffffff","overlay_color":"#000000","overlay_opacity":0}},"image_bWfFx8":{"type":"image","settings":{"image":"shopify:\/\/shop_images\/Baghera_7.jpg","title":"","heading_tag":"h4","link_url":"","link_text":"","mobile_text_position":"place-self-center text-center","desktop_column_span":2,"desktop_row_span":2,"desktop_text_position":"sm:place-self-center sm:text-center","background":"#000000","background_gradient":"","text_color":"#ffffff","text_gradient":"","button_background":"#000000","button_text_color":"#ffffff","overlay_color":"#000000","overlay_opacity":0}},"image_et8whe":{"type":"image","settings":{"image":"shopify:\/\/shop_images\/Baghera_4.jpg","title":"","heading_tag":"h4","link_url":"","link_text":"","mobile_text_position":"place-self-center text-center","desktop_column_span":2,"desktop_row_span":1,"desktop_text_position":"sm:place-self-center sm:text-center","background":"#000000","background_gradient":"","text_color":"#ffffff","text_gradient":"","button_background":"#000000","button_text_color":"#ffffff","overlay_color":