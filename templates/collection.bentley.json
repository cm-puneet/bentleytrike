,"settings":{"full_width":false,"content_width":"medium","text_position":"center","background":"#d9d0c5","background_gradient":"","text_color":"#000000"}},"media_with_text_Mgi7df":{"type":"media-with-text","blocks":{"image_9jUyr9":{"type":"image","settings":{"image":"shopify:\/\/shop_images\/Ride-on_Collection_LP_Mobile_65d438bf-0d0f-45c9-8b15-2a5f8b7ca569.png","media_width":50,"media_position":"start","text_position":"place-self-center text-center","icon":"none","icon_width":48,"subheading":"","title":"Modern Elegance in Every Detail","content":"<p>The Bentley Ride-On Cars collection brings the luxury of modern automotive design to life for young drivers. Each model is a miniature replica of Bentley's iconic vehicles, offering children a stylish, high-end driving experience.<\/p>","link_text":"","link_url":"","background":"#d9d0c5","background_gradient":"","text_color":"#000000","text_gradient":"","button_background":"","button_text_color":""}},"image_NHnBg4":{"type":"image","settings":{"image":"shopify:\/\/shop_images\/055_168_974ee57b-b714-4ce7-8f25-eade743c19cd.png","media_width":50,"media_position":"start","text_position":"place-self-center text-center","icon":"none","icon_width":48,"subheading":"","title":"Building Confidence Behind the Wheel","content":"<p>By allowing your child to take the wheel, they develop confidence and essential motor skills, helping build independence and decision-making abilities, all while enjoying a fun and safe driving experience.<\/p>","link_text":"","link_url":"","background":"#d9d0c5","background_gradient":"","text_color":"#000000","text_gradient":"","button_background":"","button_text_color":""}}},"block_order":["image_9jUyr9","image_NHnBg4"],"settings":{"full_width":false,"alternate_media_position":true,"spacing":"small"}},"press_iJUY6T":{"type":"press","blocks":{"quote_XfCXD9":{"type":"quote","settings":{"logo_width":100,"author":"","content":"The kids ride-on car is nicely built. The features like the front and rear lights are cool. The lite gauge area is nice. Easy to assemble. Overall a great kids car for the price.","show_rating":true,"rating":5}},"quote_xVQURz":{"type":"quote","settings":{"logo_width":100,"author":"","content":"A stunning and well-designed Bentley ride-on! Perfect for little drivers with smooth handling and easy controls. My son loves it—an exciting and stylish gift! Highly recommend!","show_rating":true,"rating":5}}},"block_order":["quote_XfCXD9","quote_xVQURz"],"settings":{"full_width":true,"content_size":"medium","background":"#d9d0c5","background_gradient":"","text_color":"","heading_color":"","heading_gradient":"","logo_item_background":"","logo_item_border":""}},"testimonials_Tt9Ryi":{"type":"testimonials","blocks":{"testimonial_D9W4iN":{"type":"testimonial","settings":{"round_avatar":true,"show_rating":true,"rating":5,"author":"Irina, D.","title":"Luxury on Wheels for My Little One!","content":"<p>I bought this beautiful green Bentley for my son Amir’s 2nd birthday, and it has been an absolute joy! The design is stunning, just like the real thing, with a sleek finish and amazing attention to detail. The ride is smooth, and the controls are easy to use, making it perfect for little drivers. Amir absolutely loves it, and seeing his excitement every time he gets in is priceless! A fantastic gift that combines style, fun, and comfort—highly recommend it!<\/p>"}},"testimonial_NW78di":{"type":"testimonial","settings":{"round_avatar":true,"show_rating":true,"rating":5,"author":"James G.","title":"Bentley GT","content":"<p>The kids car is nicely built. The features like the front and rear lights are cool. The lite gauge area is nice. Easy to assemble. Overall a great kids car for the price.<\/p>"}},"testimonial_xXhNmg":{"type":"testimonial","settings":{"round_avatar":true,"show_rating":true,"rating":4,"author":"Joshua A.","title":"Testimonial 3","content":"<p>Share what your customers are saying about your products, customer service or shipping rates.<\/p>"}}},"bloc