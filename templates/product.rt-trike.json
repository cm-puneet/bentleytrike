lignment":"start","icon_position":"stacked","icon":"none","icon_width":20,"title":"Max Weight:","content":"<p>up to 25 kilograms<\/p>","background":"#d9d0c5","text_color":"#1a1a1a"}},"offer_WtbX38":{"type":"offer","disabled":true,"settings":{"text_alignment":"start","icon_position":"stacked","icon":"none","icon_width":20,"title":"Feature","content":"<p>Compact fold<\/p>","background":"#f2e9e4","text_color":"#1a1a1a"}},"associated_products_YXTBbY":{"type":"associated_products","settings":{"title":"COMPLETE YOUR RITO TRIKE","stack_products":false,"products_count":5,"background":"","text_color":""}}},"block_order":["title","badges","price","rating","inventory_Cibqgw","product_variations_WFpMqc","quantity_selector","text_q6Hc7E","description","variant_picker","buy_buttons","payment_terms","offer_TCPYbU","offer_EWXTY8","offer_WtbX38","associated_products_YXTBbY"],"settings":{"full_width":true,"show_fixed_add_to_cart":true,"desktop_media_width":55,"desktop_media_layout":"carousel_thumbnails_bottom","mobile_media_size":"contained","mobile_carousel_control":"thumbnails","enable_video_autoplay":true,"enable_video_looping":true,"enable_image_zoom":true,"max_image_zoom_level":3,"background":"","background_gradient":"","text_color":"","input_background":"rgba(0,0,0,0)","input_text_color":""}},"accordion_content_EGhnWC":{"type":"accordion-content","blocks":{"item_xPccUw":{"type":"item","settings":{"icon":"none","icon_width":20,"title":"DESIGN","content":"<p>The Rito Trike is built to evolve with your child, offering a seamless transition through every stage of development. With multiple footrests and easily removable parts, it provides a perfect fit from 10 months to 36+ months, ensuring comfort, support, and lasting enjoyment.<\/p>","page":""}},"item_tVpzTf":{"type":"item","disabled":true,"settings":{"icon":"none","icon_width":20,"title":"SPECIFICATION","content":"<p>REAR BRAKE: Yes<br\/><br\/>SEAT BELT: 5-point equipped with magnetic buckle<br\/><br\/>BASKET WITH COVER: Yes<br\/><br\/>FOOTRESTS: Basic (foldable) + accessory portable<br\/>(for infants)<br\/><br\/>PARENT RIDE CONTROL HANDLEBAR: Height adjustable, two-position<br\/><br\/>WHEEL DIAMETER:<br\/>12 inches (front wheel)<br\/>10 inches (rear wheels)<br\/><br\/>ADJUSTABLE BACK SUPPORT:<br\/>Two-position<br\/><br\/>FREE HANDLE BAR FUNCTION:Yes<br\/><br\/>STORAGE BAG: Compact, removable<br\/><br\/>SEAT COVER: Removable and machine washable<br\/><br\/>HEADRES: Yielding soft headrest with stitched Bentley<br\/>badge<br\/><br\/>WHEEL FENDERS: Yes<br\/><br\/>USED MATERIALS:<br\/>Iron, PVC, PP, ABC, TPR<br\/><br\/>FOLDABLE CANOPY: Two-position<br\/>FREEWHEEL FUNCTION: Yes<br\/><br\/>SEAT ROTATING FUNCTION: 180 grees<\/p>","page":"bentley-trike-assembly"}},"item_QMVwhR":{"type":"item","settings":{"icon":"none","icon_width":20,"title":"HOW TO ASSEMBLE","content":"<p>Setting up your Rito Trike is simple! Follow along with our step-by-step assembly <a href=\"https:\/\/www.youtube.com\/watch?v=wJTaCZwJHKs\" target=\"_blank\" title=\"https:\/\/www.youtube.com\/watch?v=wJTaCZwJHKs\"><em><strong>video guide<\/strong><\/em><\/a><em><strong> <\/strong><\/em>to get your trike ready in no time. Watch now and have your little one riding in just a few minutes.<\/p>","page":""}},"item_LLNwn9":{"type":"item","disabled":true,"settings":{"icon":"none","icon_width":20,"title":"SPARE PARTS","content":"<p>Every journey deserves to be seamless. If any part of your Bentley Trike needs replacing, continue the experience by ordering an official Bentley spare part <a href=\"\/products\/bentley-trike-spare-parts\" target=\"_blank\" title=\"Bentley Trike Spare Parts\">here<\/a>. <\/p>","page":""}},"item_H639BW":{"type":"item","disabled":true,"settings":{"icon":"none","icon_width":20,"title":"WARRANTY","content":"<p>If you experience any issues with your Bentley Trike within the <strong>2-year warranty <\/strong>period, we’re here to ensure a seamless solution. Simply enter your details in the form below, and our team will assist you promptly.<\/p><p><em>Please note : Warranty coverage applies exclusively to purchases made directly from us. If purchased elsewhere, kindly reach out to the original retailer for assistance<\/em><\/p>","page":""}}},"block_order":["item_xPccUw","item_tVpzTf","item_QMVwhR","item_LLNwn9","item_H639BW"],"settings":{"full_width":true,"subheading":"","title":"The Ultimate Folding Trike","content":"<p>Rito is the ultimate 3-in-1 stroller\/trike for kids and offers the best combination of portability, style, and functionality.<\/p><p>The Rito folds down for easy storage and transport, unlike most toddler trikes, making it easier for parents to carry the trike in cars, public transport, and even tricky terrains such as escalators.<\/p>","button_text":"","button_url":"","text_position":"start","background":"","background_gradient":"","text_color":"","heading_color":"","heading_gradient":"","button_background":"","button_text_color":"","accordion_background":"","accordion_text_color":""}},"video_jdAKz9":{"type":"video","blocks":{"play_wiMKpx":{"type":"play","settings":{}},"heading_TT7nKU":{"type":"heading","settings":{"text":"","heading_tag":"h1"}}},"block_order":["play_wiMKpx","heading_TT7nKU"],"settings":{"full_width":true,"allow_transparent_header":false,"autoplay":true,"video_size":"auto","video":"shopify:\/\/files\/videos\/ritoWeb_levelupBW.mp4","external_video_url":"https:\/\/www.youtube.com\/watch?v=_9VUPq3SxOc","text_color":"#ffffff","overlay_color":"#000000","overlay_opacity":30}},"rich_text_xpUPF4":{"type":"rich-text","blocks":{"subheading_9LHF9G":{"type":"subheading","settings":{"text":"Engineered for Every Stage"}},"heading_AfYRb4":{"type":"heading","settings":{"text":"The luxury stroller that grows with your child","heading_tag":"h2","text_color":"","gradient":""}},"richtext_9j3RyK":{"type":"richtext","settings":{"content":"<p>An innovative design that can transform from stroller to tricycle —designed to grow with your child through six stages, 