ontent_width":"medium","text_position":"center","background":"rgba(0,0,0,0)","background_gradient":"","text_color":"#000000"}},"featured_collection_wjfakc":{"type":"featured-collection","settings":{"collection":"baghera-ride-on-cars","products":[],"full_width":true,"stack_products":true,"show_progress_bar":false,"products_count":50,"products_per_row_mobile":"2","products_per_row_desktop":5,"subheading":"","title":"","content":"","link_url":"","link_text":"","background":"","background_gradient":"","text_color":"","heading_color":"","heading_gradient":"","product_card_background":"","product_card_text_color":""}},"testimonials_Tt9Ryi":{"type":"testimonials","blocks":{"testimonial_D9W4iN":{"type":"testimonial","settings":{"round_avatar":true,"show_rating":true,"rating":5,"author":"Irina, D.","title":"Luxury on Wheels for My Little One!","content":"<p>I bought this beautiful green Bentley for my son Amir’s 2nd birthday, and it has been an absolute joy! The design is stunning, just like the real thing, with a sleek finish and amazing attention to detail. The ride is smooth, and the controls are easy to use, making it perfect for little drivers. Amir absolutely loves it, and seeing his excitement every time he gets in is priceless! A fantastic gift that combines style, fun, and comfort—highly recommend it!<\/p>"}},"testimonial_NW78di":{"type":"testimonial","settings":{"round_avatar":true,"show_rating":true,"rating":5,"author":"James G.","title":"Bentley GT","content":"<p>The kids car is nicely built. The features like the front and rear lights are cool. The lite gauge area is nice. Easy to assemble. Overall a great kids car for the price.<\/p>"}},"testimonial_xXhNmg":{"type":"testimonial","settings":{"round_avatar":true,"show_rating":true,"rating":4,"author":"Joshua A.","title":"Testimonial 3","content":"<p>Share what your customers are saying about your products, customer service or shipping rates.<\/p>"}}},"block_order":["testimonial_D9W4iN","testimonial_NW78di","testimonial_xXhNmg"],"disabled":true,"settings":{"full_width":true,"stack_testimonials":true,"subheading":"","title":"Testimonials","content":"","link_url":"","link_text":"","background":"","background_gradient":"","text_color":"","heading_color":"","heading_gradient":"","testimonial_card_background":"","testimonial_card_text_color":""}},"main":{"type":"main-collection","disabled":true,"settings":{"products_per_page":24,"products_per_row_mobile":"2","products_per_row_desktop":4,"filter_layout":"sidebar","show_sort_by":true,"show_filters":false,"show_filter_group_name":false,"show_filter_values_count":true,"open_first_filter_group":false}},"rich_text_fg4AAa":{"type":"rich-text","blocks":{"subheading_E6HLwn":{"type":"subheading","settings":{"text":"Timeless Durability"}},"heading_TJWMYy":{"type":"heading","settings":{"text":"Built to Last","heading_tag":"h2","text_color":"","gradient":""}},"richtext_NFnkTD":{"type":"richtext","settings":{"content":"<p>Built to last for years of adventure, Baghera Ride-On Cars handle indoor and outdoor play with ease, gliding smoothly over any flat terrain for endless fun across generations.<\/p>"}}},"block_order":["subheading_E6HLwn","heading_TJWMYy","richtext_NFnkTD"],"settings":{"full_width":false,"content_width":"medium","text_position":"center","background":"rgba(0,0,0,0)","background_gradient":"","text_color":"#000000"}},"press_iJUY6T":{"type":"press","blocks":{"quote_XfCXD9":{"type":"quote","settings":{"logo_width":100,"author":"","content":"The ride-on car is a well made, sturdy, and gorgeous item. It rolls smoothly and my grandson loves it!","show_rating":true,"rating":5}},"quote_xVQURz":{"type":"quote","disabled":true,"settings":{"logo_width":100,"author":"","content":"A stunning and well-designed Bentley ride-on! Perfect for little drivers with smooth handling and easy controls. My son loves it—an exciting and stylish gift! Highly recommend!","show_rating":true,"rating":5}}},"block_order":["quote_XfCXD9","quote_xVQURz"],"disabled