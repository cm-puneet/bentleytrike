{% doc %}
  @prompt
    I want to have image link blocks but it will only contain 5 blocks and all be centralized

{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-image-links-container-{{ ai_gen_id }} {
    display: flex;
    justify-content: center;
    align-items: center;
    gap: {{ block.settings.spacing }}px;
    padding: {{ block.settings.padding }}px 0;
    flex-wrap: wrap;
  }

  .ai-image-link-item-{{ ai_gen_id }} {
    flex: 0 0 auto;
    max-width: {{ block.settings.image_width }}px;
    transition: transform 0.3s ease;
  }

  .ai-image-link-item-{{ ai_gen_id }}:hover {
    transform: translateY(-{{ block.settings.hover_lift }}px);
  }

  .ai-image-link-{{ ai_gen_id }} {
    display: block;
    text-decoration: none;
    border-radius: {{ block.settings.border_radius }}px;
    overflow: hidden;
    box-shadow: 0 {{ block.settings.shadow_blur }}px {{ block.settings.shadow_blur | times: 2 }}px rgba(0, 0, 0, {{ block.settings.shadow_opacity | divided_by: 100.0 }});
  }

  .ai-image-link-image-{{ ai_gen_id }} {
    width: 100%;
    height: {{ block.settings.image_height }}px;
    object-fit: cover;
    display: block;
  }

  .ai-image-link-placeholder-{{ ai_gen_id }} {
    width: 100%;
    height: {{ block.settings.image_height }}px;
    background-color: #f4f4f4;
    display: flex;
    align-items: center;
    justify-content: center;
    position: relative;
  }

  .ai-image-link-placeholder-{{ ai_gen_id }} svg {
    width: 60%;
    height: 60%;
    opacity: 0.3;
  }

  .ai-image-link-empty-state-{{ ai_gen_id }} {
    position: absolute;
    bottom: 10px;
    left: 50%;
    transform: translateX(-50%);
    font-size: 12px;
    color: #666;
    text-align: center;
    pointer-events: none;
  }

  .ai-image-link-title-{{ ai_gen_id }} {
    padding: {{ block.settings.text_padding }}px;
    background-color: {{ block.settings.title_background }};
    color: {{ block.settings.title_color }};
    font-size: {{ block.settings.title_size }}px;
    font-weight: {{ block.settings.title_weight }};
    text-align: center;
    margin: 0;
  }

  @media screen and (max-width: 768px) {
    .ai-image-links-container-{{ ai_gen_id }} {
      gap: {{ block.settings.spacing | times: 0.7 }}px;
    }

    .ai-image-link-item-{{ ai_gen_id }} {
      max-width: {{ block.settings.image_width | times: 0.8 }}px;
    }

    .ai-image-link-image-{{ ai_gen_id }},
    .ai-image-link-placeholder-{{ ai_gen_id }} {
      height: {{ block.settings.image_height | times: 0.8 }}px;
    }
  }

  @media screen and (max-width: 480px) {
    .ai-image-links-container-{{ ai_gen_id }} {
      flex-direction: column;
      align-items: center;
    }

    .ai-image-link-item-{{ ai_gen_id }} {
      max-width: 100%;
      width: 100%;
      max-width: 300px;
    }
  }
{% endstyle %}<div class="ai-image-links-container-{{ ai_gen_id }}" {{ block.shopify_attributes }}>
  {% for i in (1..5) %}
    {% liquid
      assign image_key = 'image_' | append: i
      assign link_key = 'link_' | append: i
      assign title_key = 'title_' | append: i
      assign enabled_key = 'enabled_' | append: i

      assign image = block.settings[image_key]
      assign link = block.settings[link_key]
      assign title = block.settings[title_key]
      assign enabled = block.settings[enabled_key]
    %}

    {% if enabled %}
      <div class="ai-image-link-item-{{ ai_gen_id }}">
        {% if link != blank %}
          <a href="{{ link }}" class="ai-image-link-{{ ai_gen_id }}">
        {% else %}
          <div class="ai-image-link-{{ ai_gen_id }}">
        {% endif %}

        {% if image %}
          <img
            src="{{ image | image_url: width: 400 }}"
            alt="{{ image.alt | escape }}"
            class="ai-image-link-image-{{ ai_gen_id }}"
            loading="lazy"
            width="{{ block.settings.image_width }}"
            height="{{ block.settings.image_height }}"
          >
        {% else %}
          <div class="ai-image-link-placeholder-{{ ai_gen_id }}">{{ 'image' | placeholder_svg_tag }}
            <div class="ai-image-link-empty-state-{{ ai_gen_id }}">
              Add image {{ i }}
            </div>
          </div>
        {% endif %}

        {% if title != blank and block.settings.show_titles %}
          <h3 class="ai-image-link-title-{{ ai_gen_id }}">{{ title }}</h3>
        {% endif %}

        {% if link != blank %}
          </a>
        {% else %}
          </div>
        {% endif %}
      </div>
    {% endif %}
  {% endfor %}
</div>

