":"offer","disabled":true,"settings":{"text_alignment":"start","icon_position":"stacked","icon":"none","icon_width":20,"title":"Minimum Height:","content":"<p>43cm<\/p>","background":"#f2e9e4","text_color":"#1a1a1a"}},"offer_EWXTY8":{"type":"offer","settings":{"text_alignment":"start","icon_position":"stacked","icon":"none","icon_width":20,"title":"Max Weight:","content":"<p>35kg<\/p>","background":"#d9d0c5","text_color":"#1a1a1a"}},"associated_products_YXTBbY":{"type":"associated_products","settings":{"title":"COMPLETE YOUR BENTLEY BIKE","stack_products":false,"products_count":5,"background":"","text_color":""}}},"block_order":["title","badges","price","rating","inventory_Cibqgw","product_variations_WFpMqc","quantity_selector","text_q6Hc7E","description","variant_picker","buy_buttons","payment_terms","offer_TCPYbU","offer_WtbX38","offer_EWXTY8","associated_products_YXTBbY"],"settings":{"full_width":true,"show_fixed_add_to_cart":true,"desktop_media_width":55,"desktop_media_layout":"carousel_thumbnails_bottom","mobile_media_size":"contained","mobile_carousel_control":"thumbnails","enable_video_autoplay":true,"enable_video_looping":true,"enable_image_zoom":true,"max_image_zoom_level":3,"background":"","background_gradient":"","text_color":"","input_background":"rgba(0,0,0,0)","input_text_color":""}},"accordion_content_EGhnWC":{"type":"accordion-content","blocks":{"item_xPccUw":{"type":"item","settings":{"icon":"none","icon_width":20,"title":"DESIGN","content":"<p>Its lightweight magnesium frame takes inspiration from the sleek contours of the Bentley Continental GT, while the diamond-quilted handlebars and carbon fiber-inspired seat add a touch of automotive luxury. Designed for comfort and performance, it features aluminum rims, brake discs, and ergonomically shaped handlebars and seat for a smooth, effortless ride.<\/p>","page":""}},"item_tVpzTf":{"type":"item","settings":{"icon":"none","icon_width":20,"title":"SPECIFICATION","content":"<p><strong>Product weight:<\/strong> 4.55kg<br\/><strong>Magnesium frame weight:<\/strong> 650 g<br\/>Product size (without packaging): 92cm x 16cm x 42.5cm<br\/><strong>Frame<\/strong>:Magnesium alloy<br\/><strong>Rims: <\/strong>Aluminum<br\/><strong>Fork:<\/strong> Steel with carbon fiber painting<br\/><strong>Seat: <\/strong>Eco-leather<br\/><strong>Wheels:<\/strong> 12-inch air filled rubber tyres with tread<br\/><strong>Rear brakes:<\/strong> Opposed piston type cable brake disc 140 mm diameter<br\/><strong>Materials used: <\/strong>Magnesium Alloy, Steel, Rubber, PU, PP, TPR, Eco-leather<br\/><strong>Seat adjustment:<\/strong> Seat height: minimum 370 mm, maximum 415 mm<br\/><strong>Rear brakes adjustment:<\/strong> Yes<\/p>","page":"bentley-trike-assembly"}},"item_QMVwhR":{"type":"item","settings":{"icon":"none","icon_width":20,"title":"HOW TO ASSEMBLE","content":"<p>Assembling your Bentley Balance Bike is simple and straightforward. With our step-by-step video guides, you’ll have it ready to ride in no time. Follow along and get your little one cruising in style!<br\/><br\/><a href=\"https:\/\/cdn.shopify.com\/videos\/c\/o\/v\/30be1e2ce7ed4d939797e30f48e0ddb5.mp4\" target=\"_blank\" title=\"https:\/\/cdn.shopify.com\/videos\/c\/o\/v\/30be1e2ce7ed4d939797e30f48e0ddb5.mp4\">How to Assemble<\/a><br\/><a href=\"https:\/\/cdn.shopify.com\/videos\/c\/o\/v\/6114e358197e4833a8f5707e54ca6439.mp4\" target=\"_blank\" title=\"https:\/\/cdn.shopify.com\/videos\/c\/o\/v\/6114e358197e4833a8f5707e54ca6439.mp4\">Disk Brake Setting<br\/><\/a><br\/>Download the manual <a href=\"https:\/\/cdn.shopify.com\/s\/files\/1\/0008\/3368\/3521\/files\/Bentley_Balance_Bike_manual_instruction.pdf?v=1741883330\" target=\"_blank\" title=\"https:\/\/cdn.shopify.com\/s\/files\/1\/0008\/3368\/3521\/files\/Bentley_Balance_Bike_manual_instruction.pdf?v=1741883330\">here.<\/a><\/p>","page":""}},"item_LLNwn9":{"type":"item","disabled":true,"settings":{"icon":"none","icon_width":20,"title":"SPARE PARTS","content":"<p>Every journey deserves to be seamless. If any part of your Bentley Trike needs replacing, continue the experience by ordering an official Bentley spare part <a href=\"\/products\/bentley-trike-spare-parts\" target=\"_blank\" title=\"Bentley Trike Spare Parts\">here<\/a>. <\/p>","page":""}},"item_H639BW":{"type":"item","disabled":true,"settings":{"icon":"none","icon_width":20,"title":"WARRANTY","content":"<p>If you experience any issues with your Bentley Trike within the <strong>2-year warranty <\/strong>period, we’re here to ensure a seamless solution. Simply enter your details in the form below, and our team will assist you promptly.<\/p><p><em>Please note : Warranty coverage applies exclusively to purchases made directly from us. If purchased elsewhere, kindly reach out to the original retailer for assistance<\/em><\/p>","page":""}}},"block_order":["item_xPccUw","item_tVpzTf","item_QMVwhR","item_LLNwn9","item_H639BW"],"settings":{"full_width":true,"subheading":"","title":"Your child's first biking experience redefined","content":"<p>Crafted in collaboration with Bentley Motors Limited, the Bentley Balance Bike showcases the brand’s signature attention to detail and unmistakable design.<\/p>","button_text":"","button_url":"","text_position":"start","background":"","background_gradient":"","text_color":"","heading_color":"","heading_gradient":"","button_background":"","button_text_color":"","accordion_background":"rgba(0,0,0,0)","accordion_text_color":""}},"video_jdAKz9":{"type":"video","blocks":{"play_wiMKpx":{"type":"play","settings":{}},"heading_TT7nKU":{"type":"heading","settings":{"text":"","heading_tag":"h1"}}},"block_order":["play_wiMKpx","heading_TT7nKU"],"settings":{"full_width":true,"allow_transparent_header":false,"autoplay":true,"video_size":"auto","video":"shopify:\/\/files\/videos\/Balance bike.mp4","external_video_url":"https:\/\/www.youtube.com\/watch?v=_9VUPq3SxOc","text_color":"#ffffff","overlay_color":"#000000","overlay_opacity":30}},"rich_text_xpUPF4":{"type":"rich-text","blocks":{"subheading_9LHF9G":{"type":"subheading","settings":{"text":"Engineered for Every Stage"}},"heading_AfYRb4":{"type":"heading","settings":{"text":"The luxury stroller that grows with your child","heading_tag":"h2","text_color":"","gradient":""}},"richtext_9j3RyK":{"type":"richtext","settings":{"content":"<p>An innovative design that can transform from stroller to tricycle —designed to grow with your child through six stages, from 12 months and beyond.<\/p>"}}},"block_order":["subheading_9LHF9G","heading_AfYRb4","richtext_9j3RyK"],"disabled":true,"settings":{"full_width":true,"content_width":"small","text_position":"center","background":"","background_gradient":"","text_color":""}},"rich_text_8hAWQk":{"type":"rich-text","blocks":{"subheading_6qwNDh":{"type":"subheading","settings":{"text":"Unmatched Safety Features"}},"heading_nXqixp":{"type":"heading","settings":{"text":"The Perfect Next Step","heading_tag":"h3","text_color":"","gradient":""}},"richtext_ifycnb":{"type":"richtext","settings":{"content":"<p>It feels like just yesterday they took their first ride in the Bentley Trike—now they're ready to explore on their own! The Bentley Balance Bike is designed for this exciting stage, combining unmatched style with premium safety features. It’s the perfect way to fuel their independence while giving you peace of mind.<\/p>"}}},"block_order":["subheading_6qwNDh","heading_nXqixp","richtext_ifycnb"],"settings":{"full_width":true,"content_width":"small","text_position":"center","background":"","background_gradient":"","text_color":""}},"multiple_images_with_text_m6VpmR":{"type":"multiple-images-with-text","blocks":{"item_ehyqMF":{"type":"item","settings":{"image":"shopify:\/\/shop_images\/Stroller.png","image_rotation_degrees":-2,"subheading":"","title":"Infant Stroller","content":"<p><strong>Stage 1: SUITABLE FOR 6 MONTHS+<br\/><\/strong><br\/>Stroller with seat facing parent. Perfect for young infants, making sure they get all your attention<\/p>","button_url":"","button_text":""}},"item_FewYQz":{"type":"item","settings":{"image":"shopify:\/\/shop_images\/seat_fiber_pad.png","image_rotation_degrees":1.5,"subheading":"","title":"Heading 2","content":"<p>Use this text to share information about your brand with your customers. Describe a product, share announcements, or welcome customers to your store.<\/p>","button_url":"","button_text":""}},"item_zWKPQH":{"type":"item","settings":{"image":"shopify:\/\/shop_images\/parent_patterned_bag.png","image_rotation_degrees":1.5,"subheading":"","title":"Heading 2","content":"<p>Use this text to share information about your brand with your customers. Describe a product, share announcements, or welcome customers to your store.<\/p>","button_url":"","button_text":""}}},"block_order":["item_ehyqMF","item_FewYQz","item_zWKPQH"],"disabled":true,"settings":{"full_width":true,"images_layout":"stacked","collage_images_alignment":"middle","background":"","background_gradient":"","text_color":"","button_background":"","button_text_color":""}},"timeline_HkEVdC":{"type":"timeline","blocks":{"slide_g44kbY":{"type":"slide","settings":{"image":"shopify:\/\/shop_images\/Stroller.png","navigation_label":"Stage 1","subheading":"SUITABLE FOR 6 MONTHS+","title":"Infant Stroller","content":"<p>Stroller with seat facing parent. Perfect for young infants, making sure they get all your attention<\/p>"}},"slide_cEnwfb":{"type":"slide","settings":{"navigation_label":"1960","subheading":"Subheading","title":"Heading","content":"<p>Use this text to share information about your brand with your customers. Describe a product, share announcements, or welcome customers to your store.<\/p>"}},"slide_gxBnpi":{"type":"slide","settings":{"navigation_label":"1966","subheading":"Subheading","title":"Heading","content":"<p>Use this text to share information about your brand with your customers. Describe a product, share announcements, or welcome customers to your store.<\/p>"}}},"block_order":["slide_g44kbY","slide_cEnwfb","slide_gxBnpi"],"disabled":true,"settings":{"full_width":true,"background":"","background_gradient":"","text_color":""}},"ss_slider_8_MfPxLU":{"type":"ss-slider-8","blocks":{"toggle_QMVnUf":{"type":"toggle","settings":{"image":"shopify:\/\/shop_images\/Bentley_Balance_2_750x_bb7914f1-4a2b-4ac1-9a5c-02cff6480c07.webp","badge":"","time":"","title":"Reliable Disc Brakes for Confident Riding","text":"<p>Disk brakes that you can only find on the best road bikes for adults, come standard on these Bentley Balance Bikes.<\/p><p><br\/>We go the extra mile to make sure your little one is well protected when taking their first steps into the world of biking.<\/p>","button":"","button_url":""}},"toggle_nbemMh":{"type":"toggle","settings":{"image":"shopify:\/\/shop_images\/Aluminum_wheel_rims.jpg","badge":"","time":"","title":"Magnesium Alloy Frame","text":"<p>Developed to be exceptionally strong yet lightweight. It can effectively support up to 35 kg of weight at only 650 g itself.<\/p><p><br\/>This innovative design makes the Bentley balance bike easily portable yet robust.<\/p>","button":"","button_url":""}},"toggle_J7U8zB":{"type":"toggle","settings":{"image":"shopify:\/\/shop_images\/Magnesium_Alloy.jpg","badge":"","time":"","title":"Aluminum Wheel Rims","text":"<p>Designed to withstand high degrees of curb weight whilst decreasing the overall mass of the bike. This creates a lower than usual rotational weight, allowing your child to effortlessly propel the bike forward.<\/p>","button":"","button_url":""}},"toggle_UMznCd":{"type":"toggle","settings":{"image":"shopify:\/\/shop_images\/ergonomic_adjustable_seat.jpg","badge":"","time":"","title":"Eco-leather & Ergonomic Adjustable Seat","text":"<p>Features a carbon fibre inspired pattern that provides the perfect combination of style and comfort.<br\/><br\/>The ergonomic adjustable seat allows the bike to be tailored to suit your child's individual needs and grow together.<\/p>","button":"","button_url":""}},"toggle_6anEEk":{"type":"toggle","settings":{"image":"shopify:\/\/shop_images\/airfilled_wheels.jpg","badge":"","time":"","title":"Air Filled 12-inch Rubber Tires","text":"<p>These rubber tiles further supports your child's comfort, helping balance out uneven surfaces and reduce overall impact.<\/p>","button":"","button_url":""}},"toggle_LnUXnj":{"type":"toggle","disabled":true,"settings":{"image":"shopify:\/\/shop_images\/10_96f27264-ef75-4e59-a4ce-4ae492082de3.jpg","badge":"","time":"","title":"Replica Continental GT Mulliner Wheels","text":"<p>The tricycle’s wheels mirror the iconic Mulliner GT rims with absolute precision. The signature Bentley logo sits at the center, encircled by the <strong>\"Bentley Mulliner\"<\/strong> engraving—just like the originals. <br\/><br\/>Adding to its exclusivity, the self-leveling wheel cap keeps the <strong>Bentley \"B\"<\/strong> perfectly upright, even as the tricycle glides forward. A masterpiece in motion.<\/p>","button":"","button_url":""}},"toggle_8kFNXA":{"type":"toggle","disabled":true,"settings":{"image":"shopify:\/\/shop_images\/11.jpg","badge":"","time":"","title":"Anti-Slide Pedals","text":"<p>The new metal pedals with anti-slide surface design are the exact replica of the Bentley Mulliner gas pedal.<\/p>","button":"","button_url":""}}},"block_order":["toggle_QMVnUf","toggle_nbemMh","toggle_J7U8zB","toggle_UMznCd","toggle_6anEEk","toggle_LnUXnj","toggle_8kFNXA"],"settings":{"slider_gap":100,"slider_gap_mobile":40,"slider_view_mobile":1.2,"slide_gap":50,"slide_gap_mobile":20,"image_radius":0,"image_border_thickness":0,"image_ratio":"square","image_ratio_mobile":"square","slide_content_align":"left","slide_content_align_mobile":"center","slide_content_vertical_align":"center","badge_padding_horizontal":20,"badge_padding_horizontal_mobile":16,"badge_padding_vertical":8,"badge_padding_vertical_mobile":8,"badge_radius":100,"badge_border_thickness":0,"badge_custom":false,"badge_font":"playfair_display_n4","badge_size":18