9":{"type":"item","settings":{"image":"shopify:\/\/shop_images\/Seat_backrest.jpg","stretch_image":true,"link_text":"","link_url":"","background":"","text_color":"#ffffff","overlay_color":"#000000","overlay_opacity":0}},"item_Rx4tgV":{"type":"item","settings":{"image":"shopify:\/\/shop_images\/Safety_Guard.jpg","stretch_image":true,"link_text":"","link_url":"","background":"","text_color":"#ffffff","overlay_color":"#000000","overlay_opacity":0}},"item_ewK6Th":{"type":"item","settings":{"image":"shopify:\/\/shop_images\/Rear_basket.jpg","stretch_image":true,"link_text":"","link_url":"","background":"","text_color":"#ffffff","overlay_color":"#000000","overlay_opacity":0}},"item_xQTcfE":{"type":"item","settings":{"image":"shopify:\/\/shop_images\/Tools.jpg","stretch_image":true,"link_text":"","link_url":"","background":"","text_color":"#ffffff","overlay_color":"#000000","overlay_opacity":0}}},"block_order":["item_PTm4Ea","item_qAzxQJ","item_wLwDkF","item_pgP683","item_KxVJpH","item_8PAqHE","item_bmejE9","item_Rx4tgV","item_ewK6Th","item_xQTcfE"],"settings":{"full_width":false,"block_size":"medium","subheading":"","title":"","content":"","link_url":"","link_text":"","background":"","background_gradient":"","text_color":"","heading_color":"","heading_gradient":""}},"rich_text_BfpDDc":{"type":"rich-text","blocks":{"heading_KbGnfy":{"type":"heading","settings":{"text":"Step-by-Step Guide","heading_tag":"h3","text_color":"","gradient":""}},"richtext_9aR366":{"type":"richtext","settings":{"content":"<p>Assemble your Bentley Trike with ease using our detailed step-by-step guide. From unboxing to the final touches, we’ll walk you through every step to ensure a smooth and hassle-free setup.<\/p>"}}},"block_order":["heading_KbGnfy","richtext_9aR366"],"settings":{"full_width":false,"content_width":"medium","text_position":"center","background":"rgba(0,0,0,0)","background_gradient":"","text_color":"#000000"}},"multi_column_UwkUA8":{"type":"multi-column","blocks":{"item_TKTewU":{"type":"item","settings":{"image":"shopify:\/\/shop_images\/Step_1_1080x_c2b1b519-6b5f-4e31-b01b-8778ea24a5a5.jpg","column_size":"3","title":"Step 1","heading_tag":"h4","content":"<p>Insert the Front Wheel (C) into the frame (A).<\/p>","link_url":"","link_text":"","link_style":"link"}},"item_6jcG34":{"type":"item","settings":{"image":"shopify:\/\/shop_images\/Step_2a_1080x_dde8fe48-eb3c-4a8e-9546-98385c0dda0b.jpg","column_size":"3","title":"Step 2 (A)","heading_tag":"h4","content":"<p>Insert the handle bar (B) into the frame (A) and tighten with the provided allen key.<\/p>","link_url":"","link_text":"","link_style":"link"}},"item_DWtzLb":{"type":"item","settings":{"image":"shopify:\/\/shop_images\/Step_3_1080x_993f7c00-8551-49b7-9e4d-d761c71d7e32.jpg","column_size":"3","title":"Step 2 (B)","heading_tag":"h4","content":"<p>Align the handle bar and tighten the built in screw with the small allen key (tighten carefully to avoid stripping the thread on the screw). Pull down and snap the cover in place after finishing.<\/p>","link_url":"","link_text":"","link_style":"link"}},"item_bMp3k4":{"type":"item","settings":{"image":"shopify:\/\/shop_images\/Step_3_360x_ff1c4a76-cc02-4be3-be00-acc902b3eec9.jpg","column_size":"3","title":"Step 3","heading_tag":"h4","content":"<p>Install the seat (g) onto the frame (a) and the headrest bracket (g1) into the seat (G). Tighten the plastic bolt to ensure a secure fit.<\/p>","link_url":"","link_text":"","link_style":"link"}},"item_CdGrEp":{"type":"item","settings":{"image":"shopify:\/\/shop_images\/Step_4_360x_c6404b81-8664-464c-a181-952384111235.jpg","column_size":"3","title":"Step 4","heading_tag":"h4","content":"<p>Insert the safety guard (I) into the seat (G). The safety guard snaps in at the front. press down on both sides to release and open.<\/p>","link_url":"","link_text":"","link_style":"link"}},"item_wU7X9J":{"type":"item","settings":{"image":"shopify:\/\/shop_images\/Step_5_360x_c8dfc025-d42a-45d8-9b36-3e5649282173.jpg","column_size":"3","title":"Step 5","heading_tag":"h4","content":"<p>Insert the canopy (e) into the sides of the safety guard (i).<\/p>","link_url":"","link_text":"","link_style":"link"}},"item_qJThym":{"type":"item","settings":{"image":"shopify:\/\/shop_images\/Step_6_540x_8f251962-703d-480a-88c8-f9e4fff0d900.jpg","column_size":"3","title":"Step 6","heading_tag":"h4","content":"<p>Insert the pushbar (f) into the frame (a), lock the lever, and attach the bag (h). 6A: Slide the push handle (f) into the frame (a) with the red lever down, then lift to lock. 6B: Connect the top and bottom push handle parts, adjusting the height as needed.<\/p>","link_url":"","link_text":"","link_style":"link"}},"item_cHdJey":{"type":"item","settings":{"image":"shopify:\/\/shop_images\/Step_7_540x_4ac0a85c-c4b1-41e8-abe2-9958aaaa981d.jpg","column_size":"3","title":"Step 7","heading_tag":"h4","content":"<p>Insert the basket (j) onto the back of the frame (a). It will self tighten with the magnetic clip that is built in.<\/p><p>Then insert the infant footrests if needed into the slots under the seat cushion as pictured above.<\/p>","link_url":"","link_text":"","link_style":"link"}}},"block_order":["item_TKTewU","item_6jcG34","item_DWtzLb","item_bMp3k4","item_CdGrEp","item_wU7X9J","item_qJThym","item_cHdJey"],"settings":{"full_width":true,"stack_on_mobile":false,"gap":"medium","text_alignment":"start","subheading":"","title":"","content":"","background":"","background_gradient":"","text_color":""}},"rich_text_AkpxA4":{"type":"rich-text","blocks":{"heading_DVQKYt":{"type":"heading","settings":{"text":"Explore Our Bentley Trike Collection","heading_tag":"h3","text_color":"","gradient":""}},"richtext_e6beAj":{"type":"richtext","settings":{"content":"<p>Experience luxury at every turn with the <strong>Officially Licensed Bentley Collection<\/strong>. <br\/>Each product embodies elegance, craftsmanship, and innovation.<\/p>"}},"button_dzJw9L":{"type":"button","settings":{"style":"fill","size":"xl","tex